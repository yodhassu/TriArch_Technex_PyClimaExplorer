# ═══════════════════════════════════════════════════════════════
#  PyClimaExplorer — Environment Variables
#  TECHNEX'26 · IIT BHU
#
#  IMPORTANT:
#    1. Copy this file and rename to  .env
#    2. Fill in your actual keys below
#    3. NEVER commit .env to git — it is already in .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Gemini (AI Climate Analyst) ──────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-google-gemini-api-key-here

# ── Copernicus CDS (ERA5 data download) ─────────────────────────
# Get your key at: https://cds.climate.copernicus.eu/ → Profile
# Format is:  UID:API-KEY
CDS_API_KEY=your-uid:your-api-key
CDS_API_URL=https://cds.climate.copernicus.eu/api

# ── Flask ────────────────────────────────────────────────────────
FLASK_SECRET_KEY=your-secret-key-here-change-this
FLASK_DEBUG=false
GEMINI_MODEL=gemini-2.5-flash
